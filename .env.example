# ============================================================
#  Command Board — environment
#  Copy this file to ".env" and fill in the values.
#  Leave Airtable blank to run in DEMO MODE (in-memory data).
# ============================================================

# ---- Airtable: the database / source of truth ----
# 1. Create a base at https://airtable.com (an empty base is fine).
# 2. Create a Personal Access Token: https://airtable.com/create/tokens
#    Scopes: data.records:read, data.records:write, schema.bases:read, schema.bases:write
#    Access: add the base you created.
# 3. Grab the Base ID (starts with "app...") from https://airtable.com/api or the base URL.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Optional — override table names (defaults shown). Usually leave these alone.
# AIRTABLE_PROJECTS_TABLE=Projects
# AIRTABLE_TASKS_TABLE=Tasks
# AIRTABLE_SETTINGS_TABLE=Settings

# ---- GitHub: connected source (read + write issues) ----
# A token with access to your repos' issues.
# Fine-grained PAT: Issues = Read and write, Contents = Read.  (or a classic PAT with "repo")
# https://github.com/settings/tokens
GITHUB_TOKEN=

# ---- App password (optional) ----
# If set, the app asks for this once per device and stores a cookie.
# Leave blank to run with no lock (fine for a private host).
APP_PASSWORD=
